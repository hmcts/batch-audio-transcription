# ── Core ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=local
DATABASE_CONNECTION_STRING=postgresql://dev:devpass@localhost:5432/transcription_svc

# ── Azure Speech ──────────────────────────────────────────────────────────────
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_ENDPOINT=https://your-region.cognitiveservices.azure.com

# ── Azure Storage ─────────────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
AZURE_STORAGE_CONTAINER_NAME=your-container

# ── Service ───────────────────────────────────────────────────────────────────
LOCAL_API_KEY=local-dev-key-change-me
BATCH_POLL_INTERVAL_SECONDS=30
BATCH_TRANSCRIPTION_THRESHOLD_HOURS=2.0

# ── Webhook ───────────────────────────────────────────────────────────────────
WEBHOOK_TIMEOUT_SECONDS=30.0
WEBHOOK_MAX_RETRIES=3

# ── Optional ──────────────────────────────────────────────────────────────────
# LOW_CONFIDENCE_THRESHOLD=0.7
# SENTRY_DSN=https://your-sentry-dsn
