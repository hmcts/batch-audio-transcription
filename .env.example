# ── Core ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=local
DATABASE_CONNECTION_STRING=postgresql://dev:devpass@localhost:5432/transcription_svc

# ── Azure Speech ──────────────────────────────────────────────────────────────
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_ENDPOINT=https://your-region.cognitiveservices.azure.com

# ── Azure Storage ─────────────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
AZURE_STORAGE_CONTAINER_NAME=your-container
# Local dev only: set this to avoid mounting ~/.azure into Docker.
# Leave unset in deployed environments — Managed Identity is used instead.
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Dev-only alternative to Azure Blob Storage, for exercising the full
# upload -> Speech Batch pipeline without Storage Blob Data Contributor
# rights. NEVER set AUDIO_STORAGE_BACKEND=local outside your own machine.
# Azure Speech Batch still needs to fetch the audio over the internet, so
# LOCAL_AUDIO_BASE_URL must be a public tunnel to this API (e.g. ngrok).
# AUDIO_STORAGE_BACKEND=local
# LOCAL_AUDIO_STORAGE_DIR=./local-audio-storage
# LOCAL_AUDIO_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app

# ── Service ───────────────────────────────────────────────────────────────────
LOCAL_API_KEY=local-dev-key-change-me
BATCH_POLL_INTERVAL_SECONDS=30
BATCH_TRANSCRIPTION_THRESHOLD_HOURS=2.0

# Seeds/rotates a Caller row for the frontend BFF on migration (see
# migrations/versions/004_seed_frontend_caller.py). Locally this can just be
# LOCAL_API_KEY's value; the frontend's TRANSCRIPTION_API_KEY must match it.
FRONTEND_SERVICE_API_KEY=local-dev-key-change-me

# ── Webhook ───────────────────────────────────────────────────────────────────
WEBHOOK_TIMEOUT_SECONDS=30.0
WEBHOOK_MAX_RETRIES=3

# ── Optional ──────────────────────────────────────────────────────────────────
# LOW_CONFIDENCE_THRESHOLD=0.7
# SENTRY_DSN=https://your-sentry-dsn
